# Apache Atlas connection
ATLAS_HOST=your-atlas-server
ATLAS_PORT=21000
ATLAS_USER=admin
ATLAS_PASSWORD=changeme

# SSH Tunnel (optional - if Atlas is behind firewall)
SSH_HOST=your-ssh-host
SSH_USER=your-ssh-user
SSH_KEY_PATH=~/.ssh/id_rsa
SSH_PORT=22

# Target database schema
TARGET_SCHEMA=MY_SCHEMA
TARGET_DATABASE=MY_DATABASE
